{
  "name": "fgc-v3",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.5.2",
  "scripts": {
    "app:dev": "tsx watch src/main.ts",
    "app:start": "tsx src/main.ts",
    "web:dev": "pnpm --filter @fgc/web dev",
    "web:build": "pnpm --filter @fgc/web build",
    "web:typecheck": "pnpm --filter @fgc/web typecheck",
    "operator:profile:provision": "tsx src/operator-tools/profile-provisioning/cli.ts",
    "operator:collector:facebook": "tsx src/operator-tools/facebook-collector/cli.ts",
    "operator:collector:worker": "tsx src/operator-tools/collector-worker/cli.ts",
    "operator:profile:exercise": "tsx src/operator-tools/profile-exercise/cli.ts",
    "operator:profile:assisted-access": "tsx src/operator-tools/assisted-group-access/cli.ts",
    "operator:browser:probe": "tsx src/operator-tools/browser-probe/cli.ts",
    "dev": "tsx watch src/main.ts",
    "start": "tsx src/main.ts",
    "dev:web": "pnpm --filter @fgc/web dev",
    "build": "tsc --noEmit",
    "build:web": "pnpm --filter @fgc/web build",
    "typecheck": "tsc --noEmit",
    "typecheck:web": "pnpm --filter @fgc/web typecheck",
    "profile:provision": "tsx src/operator-tools/profile-provisioning/cli.ts",
    "collector:facebook:run": "tsx src/operator-tools/facebook-collector/cli.ts",
    "collector:worker:run": "tsx src/operator-tools/collector-worker/cli.ts",
    "profile:exercise:run": "tsx src/operator-tools/profile-exercise/cli.ts",
    "profile:assisted-access:run": "tsx src/operator-tools/assisted-group-access/cli.ts",
    "collector:browser:probe": "tsx src/operator-tools/browser-probe/cli.ts",
    "test": "vitest run",
    "test:db": "RUN_DB_TESTS=true vitest run src/infrastructure",
    "test:http:db": "RUN_HTTP_DB_TESTS=true vitest run src/interfaces/http",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "stack:dev:start": "docker compose -f docker-compose.dev.yml up --build -d",
    "stack:dev:worker:start": "docker compose -f docker-compose.dev.yml --profile worker up --build -d collector-worker",
    "stack:dev:worker:once": "docker compose -f docker-compose.dev.yml --profile worker run --rm --build -e COLLECTOR_WORKER_MODE_ARGS=--once collector-worker",
    "stack:dev:worker:logs": "docker compose -f docker-compose.dev.yml logs -f collector-worker",
    "stack:dev:stop": "docker compose -f docker-compose.dev.yml down --remove-orphans",
    "stack:dev:reset": "docker compose -f docker-compose.dev.yml down --volumes --remove-orphans",
    "stack:preview:start": "docker compose -f docker-compose.preview.yml up --build -d",
    "stack:preview:worker:start": "docker compose -f docker-compose.preview.yml --profile worker up --build -d collector-worker",
    "stack:preview:worker:once": "docker compose -f docker-compose.preview.yml --profile worker run --rm --build -e COLLECTOR_WORKER_MODE_ARGS=--once collector-worker",
    "stack:preview:worker:logs": "docker compose -f docker-compose.preview.yml logs -f collector-worker",
    "stack:preview:stop": "docker compose -f docker-compose.preview.yml down --remove-orphans",
    "stack:preview:reset": "docker compose -f docker-compose.preview.yml down --volumes --remove-orphans"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "pg": "^8.21.0",
    "playwright": "^1.56.1",
    "zod": "^4.4.3"
  }
}

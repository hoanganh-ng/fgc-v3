{
  "name": "digital-twin-profile-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.5.2",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "pnpm -r --sort build",
    "dev": "pnpm --parallel --filter @dtpm/api --filter @dtpm/web dev",
    "dev:api": "pnpm --filter @dtpm/api dev",
    "dev:web": "pnpm --filter @dtpm/web dev",
    "lint": "pnpm -r --sort lint",
    "test": "pnpm -r --sort test",
    "typecheck": "pnpm -r --sort typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.18.0",
    "eslint-plugin-vue": "^9.32.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8",
    "vue-eslint-parser": "^9.4.3"
  }
}
